-- Helper function: ดึง farm_id จาก JWT ของ user ปัจจุบัน
CREATE OR REPLACE FUNCTION auth_farm_id()
RETURNS UUID
LANGUAGE sql STABLE AS $$
    SELECT farm_id FROM workers WHERE id = auth.uid()
$$;

