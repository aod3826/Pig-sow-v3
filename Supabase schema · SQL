CREATE POLICY "farm_isolation" ON cycle_events    USING (farm_id = auth_farm_id());
CREATE POLICY "farm_isolation" ON alerts          USING (farm_id = auth_farm_id());
CREATE POLICY "farm_isolation" ON health_records  USING (farm_id = auth_farm_id());
CREATE POLICY "farm_isolation" ON pens            USING (farm_id = auth_farm_id());
CREATE POLICY "farm_isolation" ON boars           USING (farm_id = auth_farm_id());


